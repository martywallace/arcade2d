{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@arcade2d nestjs (node)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": false,
    "outDir": "dist"
  }
}
