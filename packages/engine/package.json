{
  "name": "@arcade2d/engine",
  "description": "A 2D game engine for JavaScript.",
  "version": "0.0.0",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest --coverage"
  },
  "maintainers": [
    "Marty Wallace <marty@martywallace.com> (https://martywallace.com)"
  ],
  "dependencies": {
    "pixi.js": "^8.18.1"
  },
  "devDependencies": {
    "@arcade2d/eslint-config": "workspace:*",
    "@arcade2d/tsconfig": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2"
  },
  "jest": {
    "rootDir": "./src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(ts|js|mjs)$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/../tsconfig.spec.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(earcut|@pixi/colord)/)"
    ],
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.spec.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
