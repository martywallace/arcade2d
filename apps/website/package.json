{
  "name": "@arcade2d/website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn workspace @arcade2d/root exec turbo run build --filter=@arcade2d/website^... && node scripts/sync-demos.mjs && yarn docs:api && astro dev",
    "build": "node scripts/sync-demos.mjs && yarn docs:api && astro build",
    "docs:api": "typedoc",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "astro check",
    "deploy": "yarn build && wrangler deploy"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "astro-icon": "^1.1.5"
  },
  "devDependencies": {
    "@arcade2d/demo-td-shooter": "workspace:*",
    "@arcade2d/engine": "workspace:*",
    "@astrojs/check": "^0.9.0",
    "@iconify-json/lucide": "^1.2.0",
    "@tailwindcss/vite": "^4.0.0",
    "marked": "^14.1.0",
    "shiki": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typedoc": "^0.27.0",
    "typescript": "^5.9.2",
    "wrangler": "^3.90.0"
  }
}
