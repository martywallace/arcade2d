---
import { Icon } from 'astro-icon/components';
import { REPO_URL } from '../demos';
import '../styles/global.css';

type Props = {
  title: string;
  description?: string;
  /** Render the site header/nav. Disabled on the homepage's full-screen hero. */
  header?: boolean;
};

const { title, description, header = true } = Astro.props;
const fullTitle = title === 'arcade2d' ? title : `${title} — arcade2d`;

const navLink = 'inline-flex items-center text-muted hover:text-fg hover:no-underline';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    {description && <meta name="description" content={description} />}
    <title>{fullTitle}</title>
  </head>
  <body>
    {
      header && (
        <header class="flex items-center justify-between border-b border-border px-6 py-4">
          <a class="inline-flex items-center" href="/" aria-label="arcade2d home">
            <img class="block h-10 w-auto" src="/logo.png" alt="arcade2d" width="180" height="110" />
          </a>
          <nav class="flex items-center gap-4">
            <a class={navLink} href="/demos">Demos</a>
            <a class={navLink} href="/docs">Docs</a>
            <a
              class={navLink}
              href={REPO_URL}
              target="_blank"
              rel="noopener"
              aria-label="GitHub"
            >
              <Icon name="lucide:github" class="size-5" />
            </a>
          </nav>
        </header>
      )
    }
    <main class="mx-auto max-w-[1100px] px-6 pt-8 pb-16">
      <slot />
    </main>
    <footer
      class="mx-auto flex max-w-[1100px] flex-wrap items-center justify-between gap-3 border-t border-border px-6 py-6 text-sm text-muted"
    >
      <span>&copy; {new Date().getFullYear()} arcade2d</span>
      <nav class="flex gap-5">
        <a class="text-muted hover:text-accent hover:no-underline" href="/demos">Demos</a>
        <a class="text-muted hover:text-accent hover:no-underline" href="/docs">Docs</a>
        <a
          class="text-muted hover:text-accent hover:no-underline"
          href={REPO_URL}
          target="_blank"
          rel="noopener"
        >
          GitHub
        </a>
      </nav>
    </footer>
  </body>
</html>
