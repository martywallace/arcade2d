---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import DemoGrid from '../components/DemoGrid.astro';
import { DEMOS, REPO_URL } from '../demos';
import { symbolCategories } from '../lib/api/load';
import { toSlug } from '../lib/api/slug';

// Icon + one-line blurb per documentation category. Categories themselves come
// from the engine's folder structure (symbolCategories), so this only needs a
// new entry when a brand-new top-level engine folder appears; unknown
// categories fall back to a generic icon and just their symbol count.
const CONCEPTS: Record<string, { icon: string; blurb: string }> = {
  Core: { icon: 'lucide:blocks', blurb: 'Game lifecycle, components, and the error model.' },
  World: { icon: 'lucide:globe', blurb: 'Worlds, objects, prefabs, and the per-frame update loop.' },
  Graphics: { icon: 'lucide:palette', blurb: 'Rendering — the scene graph, shapes, sprites, textures, and frame animation.' },
  Assets: { icon: 'lucide:images', blurb: 'Loading images into textures, grouped as typed, preloadable bundles.' },
  Geometry: { icon: 'lucide:ruler', blurb: 'Points, shapes, and spatial math.' },
  Input: { icon: 'lucide:keyboard', blurb: 'Keyboard and mouse state, sampled per tick.' },
  Utilities: { icon: 'lucide:wrench', blurb: 'Helpers like seeded RNG and id generation.' },
};

const concepts = symbolCategories().map((c) => ({
  title: c.title,
  slug: toSlug(c.title),
  count: c.symbols.length,
  icon: CONCEPTS[c.title]?.icon ?? 'lucide:box',
  blurb: CONCEPTS[c.title]?.blurb ?? '',
}));

const button =
  'inline-flex items-center gap-[0.45rem] rounded-md border px-[1.1rem] py-[0.55rem] text-[0.95rem] font-semibold hover:no-underline';
const buttonPrimary = `${button} border-accent bg-accent text-accent-contrast hover:border-accent-hover hover:bg-accent-hover`;
const buttonGhost = `${button} border-border bg-transparent text-fg hover:border-accent hover:bg-surface`;
---

<Layout
  title="arcade2d"
  description="arcade2d is a TypeScript 2D game engine."
  header={false}
>
  {/* Full-screen, centered hero. The `- 2rem` cancels <main>'s top padding so
      the first viewport is exactly one screen tall. */}
  <section
    class="relative flex min-h-[calc(100svh-2rem)] flex-col items-center justify-center text-center"
  >
    <h1 class="mb-6">
      {/* The source art is only 180px wide — render at (or below) native size
          so it stays crisp instead of upscaling and blurring. */}
      <img class="h-auto w-[min(180px,60vw)]" src="/logo.png" alt="arcade2d" width="180" height="110" />
    </h1>
    <p class="mx-auto max-w-[52ch] text-[1.2rem] text-muted">
      A TypeScript 2D game engine. Built around composable components,
      prefab-driven world objects, and the rendering pipeline you already know.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a class={buttonPrimary} href="/demos">
        <Icon name="lucide:gamepad-2" class="size-[1.1rem]" />
        View demos
      </a>
      <a class={buttonGhost} href="/docs">
        <Icon name="lucide:book-open" class="size-[1.1rem]" />
        Docs
      </a>
      <a class={buttonGhost} href={REPO_URL} target="_blank" rel="noopener">
        <Icon name="lucide:github" class="size-[1.1rem]" />
        GitHub
      </a>
    </div>

    <a
      class="absolute bottom-6 left-1/2 flex -translate-x-1/2 flex-col items-center gap-1.5 text-[0.8rem] uppercase tracking-[0.08em] text-muted hover:text-accent hover:no-underline"
      href="#demos"
      aria-label="Jump to demos"
    >
      <span>See the demos</span>
      <Icon name="lucide:chevron-down" class="size-[1.4rem] animate-scroll-bounce motion-reduce:animate-none" />
    </a>
  </section>

  <section id="demos" class="pb-4">
    <h2 class="mb-4 text-[1.4rem]">Demos</h2>
    <DemoGrid demos={DEMOS} />
  </section>

  <section class="pt-16 pb-8">
    <h2 class="mb-4 text-[1.4rem]">Concepts</h2>
    <p class="mb-5 text-muted">
      The engine surface, by area. Each links into the API reference.
    </p>
    <ul class="m-0 grid list-none grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4 p-0">
      {concepts.map((c) => (
        <li>
          <a
            class="flex h-full items-start gap-[0.85rem] rounded-lg border border-border px-[1.1rem] py-4 text-fg transition-colors hover:border-accent hover:bg-surface hover:no-underline"
            href={`/docs#${c.slug}`}
          >
            <span class="grid size-[2.4rem] flex-none place-items-center rounded-lg bg-accent text-accent-contrast">
              <Icon name={c.icon} class="size-[1.3rem]" />
            </span>
            <span class="flex flex-col gap-[0.2rem]">
              <span class="flex items-center gap-2 font-semibold">
                {c.title}
                <span class="rounded-full border border-border px-[0.45rem] py-[0.02rem] text-[0.7rem] font-semibold text-muted">
                  {c.count}
                </span>
              </span>
              {c.blurb && <span class="text-[0.9rem] text-muted">{c.blurb}</span>}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
