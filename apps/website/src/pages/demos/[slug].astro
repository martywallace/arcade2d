---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { DEMOS, findDemo, demoSourceUrl } from '../../demos';

export function getStaticPaths() {
  return DEMOS.map((demo) => ({ params: { slug: demo.slug } }));
}

const { slug } = Astro.params;
const demo = findDemo(slug!);

if (!demo) {
  return Astro.redirect('/demos');
}

const embedSrc = `/embeds/${demo.slug}/index.html`;
---

<Layout title={demo.title} description={demo.description}>
  <header class="mb-5">
    <a
      href="/demos"
      class="mb-2 inline-flex items-center gap-[0.35rem] text-[0.9rem] text-muted"
    >
      <Icon name="lucide:arrow-left" class="size-4" />
      All demos
    </a>
    <h1 class="mb-[0.35rem]">{demo.title}</h1>
    <p class="m-0 max-w-[64ch] text-muted">{demo.description}</p>
    <a
      class="mt-3 inline-flex items-center gap-[0.45rem] text-[0.9rem]"
      href={demoSourceUrl(demo)}
      target="_blank"
      rel="noopener"
    >
      <Icon name="lucide:github" class="size-[1.05rem]" />
      View source on GitHub
    </a>
  </header>

  <div class="aspect-video w-full overflow-hidden rounded-lg border border-border bg-surface">
    <iframe
      class="block size-full border-0"
      src={embedSrc}
      title={demo.title}
      loading="lazy"
      allow="fullscreen; gamepad; autoplay"
      allowfullscreen></iframe>
  </div>

  {
    demo.controls && demo.controls.length > 0 && (
      <section class="mt-6" aria-label="Controls">
        <h2 class="mb-3 text-base uppercase tracking-[0.06em] text-muted">Controls</h2>
        <ul class="m-0 flex list-none flex-wrap gap-x-6 gap-y-3 p-0">
          {demo.controls.map((control) => (
            <li class="flex items-center gap-[0.6rem]">
              <kbd class="inline-block min-w-[2.25rem] rounded-md border border-b-[3px] border-border bg-surface px-[0.6rem] py-[0.3rem] text-center font-mono text-[0.85rem] leading-none text-fg">
                {control.input}
              </kbd>
              <span class="text-muted">{control.action}</span>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Layout>
