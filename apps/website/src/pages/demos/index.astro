---
import Layout from '../../layouts/Layout.astro';
import DemoGrid from '../../components/DemoGrid.astro';
import { DEMOS } from '../../demos';
---

<Layout title="Demos" description="Live arcade2d demos.">
  <h1 class="mb-2">Demos</h1>
  <p class="mb-8 max-w-[64ch] text-muted">
    Every demo is an independently-built Vite app under
    <code class="rounded border border-border bg-surface px-[0.35rem] py-[0.1rem] text-[0.9em]">demos/</code> in
    the monorepo. Each one is bundled and embedded here as-is.
  </p>

  <DemoGrid demos={DEMOS} />
</Layout>
