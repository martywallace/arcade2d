---
import Layout from '../../layouts/Layout.astro';
import ApiSidebar from '../../components/api/ApiSidebar.astro';
import { symbolCategories } from '../../lib/api/load';
import { summaryExcerpt } from '../../lib/api/comment';
import { kindLabel, kindTag } from '../../lib/api/kinds';
import { toSlug } from '../../lib/api/slug';

const groups = symbolCategories();
---

<Layout title="API Reference" description="The arcade2d engine API reference.">
  <div class="grid grid-cols-[240px_minmax(0,1fr)] items-start gap-10 max-[820px]:grid-cols-1">
    <ApiSidebar />

    <article>
      <h1 class="mb-2">API Reference</h1>
      <p class="mb-8 max-w-[60ch] text-muted">
        Generated from the engine's source. Every type, method, and parameter
        below is documented in-tree; cross-references link straight to the
        symbol they mention.
      </p>

      {groups.map((group) => (
        <section id={toSlug(group.title)} class="scroll-mt-6">
          <h2 class="mt-8 mb-3 text-[1.3rem]">{group.title}</h2>
          <ul class="m-0 grid list-none grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-3 p-0">
            {group.symbols.map((s) => (
              <li>
                <a
                  class="block h-full rounded-lg border border-border px-4 py-[0.85rem] text-fg transition-colors hover:border-accent hover:no-underline"
                  href={`/docs/${s.slug}`}
                >
                  <span class="flex items-center justify-between gap-2">
                    <code class="font-mono font-semibold text-accent">{s.reflection.name}</code>
                    <span class={`kind-tag kind-${kindTag(s.reflection.kind)} flex-none rounded border border-border px-[0.35rem] py-[0.1rem] text-[0.62rem] font-semibold uppercase tracking-[0.06em] text-muted`}>
                      {kindLabel(s.reflection.kind)}
                    </span>
                  </span>
                  <span class="mt-[0.35rem] line-clamp-3 text-[0.85rem] text-muted">
                    {summaryExcerpt(s.reflection.comment)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </article>
  </div>
</Layout>
