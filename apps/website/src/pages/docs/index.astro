---
import Layout from '../../layouts/Layout.astro';
import ApiSidebar from '../../components/api/ApiSidebar.astro';
import { symbolCategories } from '../../lib/api/load';
import { summaryExcerpt } from '../../lib/api/comment';
import { kindLabel, kindTag } from '../../lib/api/kinds';

const groups = symbolCategories();
---

<Layout title="API Reference" description="The arcade2d engine API reference.">
  <div class="docs-layout">
    <ApiSidebar />

    <article class="docs-index">
      <h1>API Reference</h1>
      <p class="lede">
        Generated from the engine's source. Every type, method, and parameter
        below is documented in-tree; cross-references link straight to the
        symbol they mention.
      </p>

      {groups.map((group) => (
        <section>
          <h2>{group.title}</h2>
          <ul class="symbol-grid">
            {group.symbols.map((s) => (
              <li>
                <a href={`/docs/${s.slug}`}>
                  <span class="symbol-grid__head">
                    <code>{s.reflection.name}</code>
                    <span class={`kind-tag kind-${kindTag(s.reflection.kind)}`}>
                      {kindLabel(s.reflection.kind)}
                    </span>
                  </span>
                  <span class="symbol-grid__summary">
                    {summaryExcerpt(s.reflection.comment)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </article>
  </div>

  <style>
    .docs-layout {
      display: grid;
      grid-template-columns: 240px minmax(0, 1fr);
      gap: 2.5rem;
      align-items: start;
    }
    h1 {
      margin: 0 0 0.5rem;
    }
    .lede {
      color: var(--muted);
      max-width: 60ch;
      margin: 0 0 2rem;
    }
    h2 {
      font-size: 1.3rem;
      margin: 2rem 0 0.75rem;
    }
    .symbol-grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 0.75rem;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    }
    .symbol-grid a {
      display: block;
      height: 100%;
      padding: 0.85rem 1rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--fg);
      transition: border-color 0.15s ease;
    }
    .symbol-grid a:hover {
      border-color: var(--accent);
      text-decoration: none;
    }
    .symbol-grid__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .symbol-grid code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-weight: 600;
      color: var(--accent);
    }
    .kind-tag {
      flex: none;
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 600;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.1rem 0.35rem;
    }
    .symbol-grid__summary {
      margin-top: 0.35rem;
      font-size: 0.85rem;
      color: var(--muted);
      /* clamp the plain-text excerpt to three lines */
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    @media (max-width: 820px) {
      .docs-layout {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
