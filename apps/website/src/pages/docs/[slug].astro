---
import Layout from '../../layouts/Layout.astro';
import Member from '../../components/api/Member.astro';
import Prose from '../../components/api/Prose.astro';
import ApiSidebar from '../../components/api/ApiSidebar.astro';
import {
  blockTags,
  renderBlockTag,
  renderSummary,
} from '../../lib/api/comment';
import { allSymbols, getSymbol, Kind, type Reflection } from '../../lib/api/load';
import { kindLabel, kindTag } from '../../lib/api/kinds';
import { renderType } from '../../lib/api/types';

export function getStaticPaths() {
  return allSymbols().map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const symbol = getSymbol(slug!);
if (!symbol) return Astro.redirect('/docs');

const ref = symbol.reflection;
const source = ref.sources?.[0];
const summaryHtml = renderSummary(ref.comment);
const classExamples = blockTags(ref.comment, '@example');

// Resolve this symbol's member groups (Constructors / Properties / ...).
const childrenById = new Map<number, Reflection>(
  (ref.children ?? []).map((c) => [c.id, c]),
);
const memberGroups = (ref.groups ?? [])
  .map((g) => ({
    title: g.title,
    members: g.children
      .map((id) => childrenById.get(id))
      .filter((m): m is Reflection => Boolean(m)),
  }))
  .filter((g) => g.members.length > 0);

const extendsTypes = ref.extendedTypes ?? [];
const implementsTypes = ref.implementedTypes ?? [];

// Type aliases: show the aliased type as a code block.
const isTypeAlias = ref.kind === Kind.TypeAlias;
const aliasHtml = isTypeAlias ? renderType(ref.type) : '';
---

<Layout title={`${ref.name} — API`} description={`API reference for ${ref.name}.`}>
  <div class="docs-layout">
    <ApiSidebar activeSlug={slug} />

    <article class="symbol">
      <header class="symbol__head">
        <span class={`kind-chip kind-${kindTag(ref.kind)}`}>{kindLabel(ref.kind)}</span>
        <h1>{ref.name}</h1>
        {source?.url && (
          <a class="symbol__source" href={source.url} target="_blank" rel="noopener">
            {source.fileName}:{source.line}
          </a>
        )}
      </header>

      {(extendsTypes.length > 0 || implementsTypes.length > 0) && (
        <div class="symbol__rel">
          {extendsTypes.length > 0 && (
            <p>
              <span class="rel-label">Extends</span>
              {extendsTypes.map((t) => <code class="sig-inline" set:html={renderType(t)} />)}
            </p>
          )}
          {implementsTypes.length > 0 && (
            <p>
              <span class="rel-label">Implements</span>
              {implementsTypes.map((t) => <code class="sig-inline" set:html={renderType(t)} />)}
            </p>
          )}
        </div>
      )}

      <Prose html={summaryHtml} />

      {isTypeAlias && (
        <code class="sig-block" set:html={aliasHtml} />
      )}

      {classExamples.length > 0 && (
        <section class="symbol__examples">
          <h2>Example</h2>
          {classExamples.map((e) => <Prose html={renderBlockTag(e)} />)}
        </section>
      )}

      {memberGroups.map((g) => (
        <section class="symbol__group">
          <h2>{g.title}</h2>
          {g.members.map((m) => <Member member={m} />)}
        </section>
      ))}
    </article>
  </div>

  <style>
    .docs-layout {
      display: grid;
      grid-template-columns: 240px minmax(0, 1fr);
      gap: 2.5rem;
      align-items: start;
    }
    .symbol__head {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .symbol__head h1 {
      margin: 0;
      font-size: 2rem;
    }
    .kind-chip {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      font-weight: 700;
      color: var(--accent-contrast);
      background: var(--accent);
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
    }
    .symbol__source {
      margin-left: auto;
      font-size: 0.85rem;
      color: var(--muted);
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }
    .symbol__rel {
      margin: 0 0 1rem;
      font-size: 0.92rem;
    }
    .symbol__rel p {
      margin: 0.25rem 0;
      display: flex;
      gap: 0.5rem;
      align-items: baseline;
      flex-wrap: wrap;
    }
    .rel-label {
      text-transform: uppercase;
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      color: var(--muted);
      font-weight: 600;
    }
    .sig-inline,
    .sig-block {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }
    .sig-block {
      display: block;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.8rem 1rem;
      margin: 0 0 1.5rem;
      overflow-x: auto;
      font-size: 0.95rem;
    }
    .symbol__group h2,
    .symbol__examples h2 {
      font-size: 1.3rem;
      margin: 2rem 0 0.25rem;
    }
    .symbol :global(.ty-link),
    .symbol :global(a) {
      color: var(--accent);
    }
    .symbol :global(.ty-intrinsic) {
      color: #b5651d;
    }
    .symbol :global(.ty-punct) {
      color: var(--muted);
    }
    @media (max-width: 820px) {
      .docs-layout {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
