---
import { symbolCategories } from '../../lib/api/load';

type Props = { activeSlug?: string };
const { activeSlug } = Astro.props;
const groups = symbolCategories();

const linkBase =
  'block py-[0.15rem] font-mono text-[0.82rem] hover:text-fg hover:no-underline';
---

<nav
  class="sticky top-6 max-h-[calc(100vh-3rem)] self-start overflow-y-auto text-[0.9rem] max-[820px]:static max-[820px]:mb-6 max-[820px]:max-h-none max-[820px]:border-b max-[820px]:border-border max-[820px]:pb-4"
  aria-label="API reference"
>
  <a class="mb-4 block font-bold text-fg" href="/docs">API Reference</a>
  {groups.map((group) => (
    <div class="mb-5">
      <h3 class="mb-[0.4rem] text-[0.72rem] uppercase tracking-[0.07em] text-muted">
        {group.title}
      </h3>
      <ul class="m-0 list-none p-0">
        {group.symbols.map((s) => (
          <li>
            <a
              href={`/docs/${s.slug}`}
              class={`${linkBase} ${s.slug === activeSlug ? 'font-semibold text-accent' : 'text-muted'}`}
            >
              {s.reflection.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>
