---
import { symbolCategories } from '../../lib/api/load';

type Props = { activeSlug?: string };
const { activeSlug } = Astro.props;
const groups = symbolCategories();
---

<nav class="api-sidebar" aria-label="API reference">
  <a class="api-sidebar__home" href="/docs">API Reference</a>
  {groups.map((group) => (
    <div class="api-sidebar__group">
      <h3>{group.title}</h3>
      <ul>
        {group.symbols.map((s) => (
          <li>
            <a
              href={`/docs/${s.slug}`}
              class={s.slug === activeSlug ? 'is-active' : ''}
            >
              {s.reflection.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>

<style>
  .api-sidebar {
    position: sticky;
    top: 1.5rem;
    align-self: start;
    max-height: calc(100vh - 3rem);
    overflow-y: auto;
    font-size: 0.9rem;
  }
  .api-sidebar__home {
    display: block;
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 1rem;
  }
  .api-sidebar__group {
    margin-bottom: 1.25rem;
  }
  .api-sidebar__group h3 {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--muted);
    margin: 0 0 0.4rem;
  }
  .api-sidebar ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .api-sidebar li a {
    display: block;
    padding: 0.15rem 0;
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.82rem;
  }
  .api-sidebar li a:hover {
    color: var(--fg);
    text-decoration: none;
  }
  .api-sidebar li a.is-active {
    color: var(--accent);
    font-weight: 600;
  }
  @media (max-width: 820px) {
    .api-sidebar {
      position: static;
      max-height: none;
      border-bottom: 1px solid var(--border);
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
    }
  }
</style>
