---
import {
  blockTags,
  firstBlockTag,
  renderBlockTag,
  renderParts,
  renderSummary,
} from '../../lib/api/comment';
import { Kind, type Reflection, type Signature } from '../../lib/api/load';
import {
  accessorLine,
  modifiers,
  propertyLine,
  signatureLine,
} from '../../lib/api/signature';
import { memberAnchor } from '../../lib/api/slug';
import { renderType } from '../../lib/api/types';
import Prose from './Prose.astro';

type Props = { member: Reflection };
const { member } = Astro.props;

const anchor = memberAnchor(member.name);
const mods = modifiers(member);

// A method/constructor can have multiple overload signatures; render each.
const isCallable = member.kind === Kind.Method || member.kind === Kind.Constructor;
const signatures: Signature[] = isCallable ? (member.signatures ?? []) : [];

function paramRows(sig: Signature) {
  return (sig.parameters ?? []).map((p) => {
    const tag = (sig.comment?.blockTags ?? []).find(
      (t) => t.tag === '@param' && t.name === p.name,
    );
    return {
      name: p.name,
      optional: Boolean(p.flags?.isOptional),
      typeHtml: renderType(p.type),
      descHtml: tag ? renderParts(tag.content) : '',
    };
  });
}
---

<div class="member" id={anchor}>
  <div class="member__head">
    {mods.length > 0 && (
      <span class="member__mods">{mods.join(' ')}</span>
    )}
    <a class="member__anchor" href={`#${anchor}`} aria-label={`Link to ${member.name}`}>#</a>
  </div>

  {member.kind === Kind.Property && (
    <code class="sig" set:html={propertyLine(member)} />
  )}
  {member.kind === Kind.Accessor && (
    <code class="sig" set:html={accessorLine(member)} />
  )}
  {member.kind === Kind.EnumMember && (
    <code class="sig" set:html={`<span class="sig-name">${member.name}</span>`} />
  )}

  {(member.kind === Kind.Property || member.kind === Kind.EnumMember) && (
    <Prose html={renderSummary(member.comment)} />
  )}
  {member.kind === Kind.Accessor && (
    <Prose html={renderSummary(member.getSignature?.comment ?? member.comment)} />
  )}

  {signatures.map((sig) => {
    const rows = paramRows(sig);
    const returns = firstBlockTag(sig.comment, '@returns');
    const throwsTags = blockTags(sig.comment, '@throws');
    const examples = blockTags(sig.comment, '@example');
    return (
      <div class="member__sig">
        <code class="sig" set:html={signatureLine(member.name, sig)} />
        <Prose html={renderSummary(sig.comment)} />

        {rows.length > 0 && (
          <div class="member__params">
            <h4>Parameters</h4>
            <ul>
              {rows.map((r) => (
                <li>
                  <code class="param-name">{r.name}{r.optional ? '?' : ''}</code>
                  <code class="param-type" set:html={r.typeHtml} />
                  {r.descHtml && <span class="param-desc"><Prose html={r.descHtml} /></span>}
                </li>
              ))}
            </ul>
          </div>
        )}

        {member.kind !== Kind.Constructor && (
          <div class="member__returns">
            <h4>Returns</h4>
            <code class="sig" set:html={renderType(sig.type)} />
            {returns && <Prose html={renderBlockTag(returns)} />}
          </div>
        )}

        {throwsTags.length > 0 && (
          <div class="member__throws">
            <h4>Throws</h4>
            {throwsTags.map((t) => (
              <Prose html={renderBlockTag(t)} />
            ))}
          </div>
        )}

        {examples.length > 0 && (
          <div class="member__examples">
            <h4>Example</h4>
            {examples.map((e) => (
              <Prose html={renderBlockTag(e)} />
            ))}
          </div>
        )}
      </div>
    );
  })}
</div>

<style>
  .member {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    scroll-margin-top: 1.5rem;
  }
  .member__head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 1.2rem;
  }
  .member__mods {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
  }
  .member__anchor {
    color: var(--border);
    text-decoration: none;
    margin-left: auto;
    font-weight: 700;
  }
  .member:hover .member__anchor {
    color: var(--muted);
  }
  .sig {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.95rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    margin: 0.4rem 0 0.8rem;
    overflow-x: auto;
    line-height: 1.5;
  }
  .member__sig {
    margin-top: 1rem;
  }
  h4 {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 1rem 0 0.5rem;
  }
  .member__params ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .member__params li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
  }
  .param-name {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-weight: 600;
    color: var(--fg);
  }
  .param-type,
  .member__returns .sig {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.88rem;
  }
  .param-type {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.05rem 0.35rem;
  }
  .param-desc {
    flex: 1 1 100%;
    color: var(--muted);
    font-size: 0.92rem;
  }
  .member__returns .sig {
    display: inline-block;
    margin: 0 0 0.5rem;
  }

  /* Token colors for rendered signatures/types. */
  .member :global(.ty-name),
  .member :global(.sig-name) {
    color: var(--fg);
  }
  .member :global(.sig-name) {
    color: var(--accent);
    font-weight: 600;
  }
  .member :global(.ty-intrinsic) {
    color: #b5651d;
  }
  .member :global(.ty-literal) {
    color: #297a3a;
  }
  .member :global(.ty-kw) {
    color: #a4329d;
  }
  .member :global(.ty-punct) {
    color: var(--muted);
  }
  .member :global(.ty-link) {
    color: var(--accent);
    text-decoration: none;
  }
  .member :global(.ty-link:hover) {
    text-decoration: underline;
  }
  .member :global(.sig-param) {
    color: var(--fg);
  }
</style>
