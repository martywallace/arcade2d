---
import { Icon } from 'astro-icon/components';
import { demoSourceUrl, type DemoEntry } from '../demos';

type Props = {
  demos: readonly DemoEntry[];
};

const { demos } = Astro.props;
---

<ul class="m-0 grid list-none grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4 p-0">
  {
    demos.map((demo) => (
      <li class="group flex flex-col overflow-hidden rounded-lg border border-border transition-colors hover:border-accent">
        <a class="block flex-1 px-[1.1rem] py-4 text-fg hover:no-underline" href={`/demos/${demo.slug}`}>
          <h3 class="mb-[0.35rem] text-[1.05rem]">{demo.title}</h3>
          <p class="m-0 text-[0.95rem] text-muted">{demo.description}</p>
        </a>
        <a
          class="flex items-center gap-[0.45rem] border-t border-border px-[1.1rem] py-[0.6rem] text-[0.85rem] text-muted hover:text-accent hover:no-underline"
          href={demoSourceUrl(demo)}
          target="_blank"
          rel="noopener"
        >
          <Icon name="lucide:github" class="size-4" />
          View source
        </a>
      </li>
    ))
  }
</ul>
